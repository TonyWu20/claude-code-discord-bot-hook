{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/.venv/bin/python ${CLAUDE_PLUGIN_ROOT}/hooks/notify_discord.py",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/.venv/bin/python ${CLAUDE_PLUGIN_ROOT}/hooks/notify_discord.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill $(cat /tmp/claude_watchdog.pid 2>/dev/null) 2>/dev/null; ${CLAUDE_PLUGIN_ROOT}/hooks/.venv/bin/python ${CLAUDE_PLUGIN_ROOT}/hooks/notify_discord.py --idle-from-stdin",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/.venv/bin/python ${CLAUDE_PLUGIN_ROOT}/hooks/notify_discord.py",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill $(cat /tmp/claude_watchdog.pid) 2>/dev/null; rm /tmp/claude_watchdog.pid",
            "async": true
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/.venv/bin/python ${CLAUDE_PLUGIN_ROOT}/hooks/notify_discord.py",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill $(cat /tmp/claude_watchdog.pid) 2>/dev/null; rm /tmp/claude_watchdog.pid",
            "async": true
          }
        ]
      }
    ]
  }
}
